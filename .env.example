# Copy this file to .env and fill in the keys for the providers you plan to use.
# Bun automatically loads .env from the current working directory.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: override the default judge model configured in bench/src/config/models.config.ts
BENCH_JUDGE_MODEL_ID=

# Local OpenAI-compatible servers (llama.cpp server, Lemonade) usually need no API key.
# Set these only if your local server requires one.
LOCAL_LLAMACPP_API_KEY=
LEMONADE_API_KEY=
